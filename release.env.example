# Copy to release.env (git-ignored). Holds signing / publishing credentials.
#
# When release.env is absent, the sign-* Make targets degrade to unsigned
# no-ops, so credential-less CI and PR builds still succeed.

# ---- macOS code signing / notarization ----
# MACOS_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# AC_NOTARY_KEY_ID=XXXXXXXXXX
# AC_NOTARY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AC_NOTARY_KEY_FILE=/path/to/AuthKey_XXXXXXXXXX.p8

# ---- Windows Authenticode ----
# WINDOWS_CERT_FILE=/path/to/cert.pfx
# WINDOWS_CERT_PASSWORD=change-me
# WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com

# ---- Publishing ----
# GITHUB_TOKEN=ghp_xxx           # GitHub Releases (provided by CI in Actions)
# HOMEBREW_TAP_TOKEN=ghp_xxx     # push formula to jfigge/homebrew-tap
